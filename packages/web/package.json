{
	"name": "economy-simulator-web",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc -b && vite build",
		"preview": "vite preview",
		"format": "bunx biome format --write .",
		"lint": "bunx biome lint .",
		"lint:fix": "bunx biome check --write .",
		"typecheck": "tsc -b --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:e2e": "playwright test"
	},
	"dependencies": {
		"@faker-js/faker": "^10.5.0",
		"@tailwindcss/vite": "^4.3.2",
		"@tanstack/react-virtual": "^3.14.5",
		"chart.js": "^4.5.1",
		"economy-simulator-data": "workspace:*",
		"economy-simulator-geography": "workspace:*",
		"economy-simulator-persistence": "workspace:*",
		"economy-simulator-simulation": "workspace:*",
		"facesjs": "^5.0.3",
		"honeycomb-grid": "^4.1.5",
		"react": "^19.2.7",
		"react-chartjs-2": "^5.3.1",
		"react-dom": "^19.2.7",
		"react-router": "^8.1.0",
		"tailwindcss": "^4.3.2"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.2",
		"@playwright/test": "^1.61.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^26.1.1",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.3",
		"jsdom": "^29.1.1",
		"typescript": "^7.0.2",
		"vite": "^8.1.3",
		"vitest": "^4.1.10"
	}
}
